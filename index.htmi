    tip:'🔑 ER target 200% — Burst damage scale ตาม energy ที่ทีมใช้\n🔑 ใส่ใน National Team (Xiangling + Bennett + Xingqiu) = ดีที่สุด\n🔑 Burst mode ช่วยชาร์จ energy ให้ทีมทุกคน\n🔑 The Catch ฟรีจาก fishing = weapon ที่คุ้มมากที่สุดในเกม'
  },
  'Zhongli': {
    el:'Geo', role:'Shield Support',
    artifact:'Tenacity of the Millelith (4pc)',
    alt:'Archaic Petra (4pc) ถ้าต้องการ Sub-DPS Geo',
    weapons:['Staff of Homa (ดีสุด HP%)','Black Tassel (F2P HP%)','Favonius Lance','Vortex Vanquisher'],
    mainStats:['Sands: HP%','Goblet: HP%','Circlet: HP%'],
    subStats:['HP% ให้ได้มากที่สุด','HP flat','Energy Recharge (ถ้าต้องการ Burst)'],
    talent:'Skill > Burst > Normal',
    book:'Gold / Prosperity — วันอังคาร/ศุกร์/อาทิตย์',
    tip:'🔑 HP target: 50,000+ HP เพื่อ shield แข็งสุด\n🔑 Jade Shield ให้ Res Shred 20% ให้ศัตรูทุกธาตุ\n🔑 กด Skill ค้างเพื่อสร้าง Pillar แบบ long hold\n🔑 แทบไม่ต้องใช้ Burst — แค่ Skill + shield ก็พอ'
  },
  'Bennett': {
    el:'Pyro', role:'Healer / ATK Buffer',
    artifact:'Noblesse Oblige (4pc)',
    alt:'Instructor (4pc) ถ้าทีมต้องการ EM boost',
    weapons:['Aquila Favonia (ดีสุด)','Festering Desire','Skyward Blade','Favonius Sword (F2P)'],
    mainStats:['Sands: Energy Recharge%','Goblet: HP%','Circlet: Healing Bonus%'],
    subStats:['Energy Recharge → 160%+','HP%','CD'],
    talent:'Burst > Skill > Normal',
    book:'Resistance / Diligence — วันพุธ/พฤหัส/อาทิตย์',
    tip:'🔑 ER 160%+ เพื่อ Burst ได้ทุก rotation\n🔑 Burst ATK buff scale ตาม Base ATK ของ Bennett เท่านั้น\n🔑 ห้ามอัพ C6 ถ้าไม่ใช้ทีม Pyro infuse (จะทำ infuse Pyro ให้ตัวหลัก)\n🔑 ใส่ได้ทุกทีม — Bennett คือ universal support ที่ดีที่สุดตลอดกาล'
  },
  'Xingqiu': {
    el:'Hydro', role:'Sub-DPS / Hydro Applicator',
    artifact:'Emblem of Severed Fate (4pc)',
    alt:'Heart of Depth (2pc) + Emblem (2pc)',
    weapons:['Sacrificial Sword (ดีสุด — reset Skill)','Favonius Sword','Jade Cutter','Iron Sting (F2P)'],
    mainStats:['Sands: ER% หรือ ATK%','Goblet: Hydro DMG Bonus%','Circlet: Crit Rate / DMG'],
    subStats:['Crit Rate/DMG','Energy Recharge → 180%+','ATK%'],
    talent:'Burst > Skill > Normal',
    book:'Gold / Diligence — วันอังคาร/ศุกร์/อาทิตย์',
    tip:'🔑 ER 180% เพื่อ Burst ทุก rotation\n🔑 Sacrificial Sword ช่วย reset Skill = Hydro application เพิ่ม\n🔑 Burst rain sword = Hydro off-field ที่ดีที่สุดใน 4★\n🔑 ใส่กับ Hu Tao, Arlecchino = Vaporize damage สูงมาก'
  },
  'Fischl': {
    el:'Electro', role:'Sub-DPS / Electro Battery',
    artifact:'Golden Troupe (4pc)',
    alt:'Thundering Fury (2pc) + Emblem (2pc)',
    weapons:['Polar Star (ดีสุด)','Thundering Pulse','Stringless (F2P ดี)','Alley Hunter'],
    mainStats:['Sands: ATK%','Goblet: Electro DMG Bonus%','Circlet: Crit Rate / DMG'],
    subStats:['Crit Rate → 60%+','Crit DMG → 120%+','ATK%','Energy Recharge'],
    talent:'Normal > Skill > Burst',
    book:'Ballad / Resistance — วันอังคาร/ศุกร์/อาทิตย์',
    tip:'🔑 Oz (รังนกอีกา) off-field damage = core ของ Fischl\n🔑 ใส่ใน Aggravate team (Dendro + Electro) = damage เพิ่ม 30%+\n🔑 C6 คือ biggest power spike ถ้า pull ได้\n🔑 ดีใน Hyperbloom, Aggravate, Superconduct team'
  },
};

/* ============================================================
   STATE (ใช้ localStorage)
============================================================ */
const STORAGE_KEYS = { resin:'gc_resin', tasks:'gc_tasks', pity:'gc_pity', owned:'gc_owned', taskDate:'gc_taskDate' };

function loadState() {
  // Check if tasks should reset (new day)
  const savedDate = localStorage.getItem(STORAGE_KEYS.taskDate);
  const today = new Date().toDateString();
  let tasks = {};
  if (savedDate === today) {
    tasks = JSON.parse(localStorage.getItem(STORAGE_KEYS.tasks) || '{}');
  } else {
    localStorage.setItem(STORAGE_KEYS.taskDate, today);
    localStorage.setItem(STORAGE_KEYS.tasks, '{}');
  }
  // Owned chars
  const savedOwned = localStorage.getItem(STORAGE_KEYS.owned);
  const ownedSet = savedOwned
    ? new Set(JSON.parse(savedOwned))
    : new Set(CHARS.filter(c=>c.owned).map(c=>c.name));

  return {
    resin: parseInt(localStorage.getItem(STORAGE_KEYS.resin) || '160'),
    tasks,
    pity: JSON.parse(localStorage.getItem(STORAGE_KEYS.pity) || '{"char":0,"wpn":0,"std":0}'),
    ownedChars: ownedSet,
    elFilter: 'all',
    ownedFilter: 'all',
    mapFilter: 'all',
    activeBuild: null,
  };
}

let S = loadState();

function saveOwned() {
  localStorage.setItem(STORAGE_KEYS.owned, JSON.stringify([...S.ownedChars]));
}

/* ============================================================
   STARS BACKGROUND
============================================================ */
function initStars() {
  const container = document.getElementById('stars');
  for (let i = 0; i < 160; i++) {
    const s = document.createElement('div');
    s.className = 'star';
    const sz = Math.random() * 2 + 0.5;
    s.style.cssText = [
      `width:${sz}px`, `height:${sz}px`,
      `left:${Math.random()*100}%`, `top:${Math.random()*100}%`,
      `--dur:${2 + Math.random()*4}s`,
      `--lo:${0.05 + Math.random()*0.12}`,
      `--hi:${0.4  + Math.random()*0.6}`,
      `animation-delay:${Math.random()*6}s`,
    ].join(';');
    container.appendChild(s);
  }
}

/* ============================================================
   TABS
============================================================ */
function switchTab(id, btn) {
  document.querySelectorAll('.section').forEach(s => s.classList.remove('active'));
  document.querySelectorAll('.tab').forEach(b => b.classList.remove('active'));
  document.getElementById('sec-'+id).classList.add('active');
  btn.classList.add('active');
}

/* ============================================================
   DAILY
============================================================ */
function initDaily() {
  const day = new Date().getDay();
  document.getElementById('today-day-label').textContent = DOMAINS[day].day;

  // Domains
  const d = DOMAINS[day];
  document.getElementById('today-domains').innerHTML = `
    <div class="domain-row">
      <div class="domain-icon">📚</div>
      <div>
        <div class="domain-name">Talent Books</div>
        <div class="domain-items">${d.talents.join(' · ')}</div>
      </div>
    </div>
    <div class="domain-row">
      <div class="domain-icon">⚔️</div>
      <div>
        <div class="domain-name">Weapon Ascension</div>
        <div class="domain-items">${d.weapons.join(' · ')}</div>
      </div>
    </div>`;

  renderTasks();
  updateResin(S.resin);
  document.getElementById('resin-slider').value = S.resin;
  renderWish();
}

function renderTasks() {
  document.getElementById('daily-tasks').innerHTML = DAILY_TASKS.map(t => {
    const done = !!S.tasks[t.id];
    return `<label class="task${done?' done':''}">
      <input type="checkbox" ${done?'checked':''} onchange="toggleTask('${t.id}',this)">
      <span class="task-label">${t.label}</span>
      ${t.badge ? `<span class="task-badge ${t.badgeClass}">${t.badge}</span>` : ''}
    </label>`;
  }).join('');
}

function toggleTask(id, el) {
  S.tasks[id] = el.checked;
  localStorage.setItem(STORAGE_KEYS.tasks, JSON.stringify(S.tasks));
  el.closest('.task').classList.toggle('done', el.checked);
}

function resetTasks() {
  if (!confirm('รีเซ็ต checklist วันนี้ทั้งหมด?')) return;
  S.tasks = {};
  localStorage.setItem(STORAGE_KEYS.tasks, '{}');
  renderTasks();
}

function updateResin(v) {
  v = parseInt(v);
  S.resin = v;
  localStorage.setItem(STORAGE_KEYS.resin, v);
  document.getElementById('resin-num').textContent = v;
  document.getElementById('resin-fill').style.width = (v/200*100)+'%';
  const rem = 200 - v;
  if (rem <= 0) {
    document.getElementById('resin-time').textContent = 'เต็มแล้ว!';
  } else {
    const h = Math.floor(rem*8/60), m = (rem*8)%60;
    document.getElementById('resin-time').textContent = `${h} ชม. ${m} น.`;
  }
}

function renderWish() {
  const TYPES = [
    {key:'char',label:'Character Event Banner',max:90,soft:75},
    {key:'wpn', label:'Weapon Event Banner',   max:80,soft:62},
    {key:'std', label:'Standard Banner',        max:90,soft:75},
  ];
  document.getElementById('wish-rows').innerHTML = TYPES.map(w => {
    const p = S.pity[w.key] || 0;
    const warn = p >= w.soft;
    return `<div class="wish-row">
      <span class="wish-name">${w.label}</span>
      <span class="wish-pity" style="color:${warn?'var(--warning)':'var(--gold-light)'}">
        ${p > 0 ? p+'/'+w.max+' pity' : '—'}
      </span>
      <input class="wish-input" type="number" min="0" max="${w.max}"
        placeholder="กรอก pity" value="${p||''}"
        oninput="updatePity('${w.key}',this.value)">
    </div>`;
  }).join('');
}

function updatePity(key, v) {
  S.pity[key] = parseInt(v) || 0;
  localStorage.setItem(STORAGE_KEYS.pity, JSON.stringify(S.pity));
  renderWish();
}

/* ============================================================
   CHARACTERS
============================================================ */
function setElFilter(el, btn) {
  S.elFilter = el;
  document.querySelectorAll('#el-filters .filter-btn').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  renderChars();
}
function setOwnFilter(o, btn) {
  S.ownedFilter = o;
  document.querySelectorAll('#own-filters .filter-btn').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  renderChars();
}

function renderChars() {
  let chars = [...CHARS];
  if (S.elFilter !== 'all') chars = chars.filter(c => c.el === S.elFilter);
  if (S.ownedFilter === 'owned')   chars = chars.filter(c =>  S.ownedChars.has(c.name));
  if (S.ownedFilter === 'missing') chars = chars.filter(c => !S.ownedChars.has(c.name));

  const grid = document.getElementById('char-grid');
  if (!chars.length) {
    grid.innerHTML = '<div class="empty" style="grid-column:1/-1"><div class="empty-icon">🔍</div>ไม่พบตัวละครที่ตรงกัน</div>';
    return;
  }

  grid.innerHTML = chars.map(c => {
    const owned = S.ownedChars.has(c.name);
    const hasBuild = !!BUILDS[c.name];
    return `<div class="char-card${owned?'':' not-owned'}" id="cc-${c.id}">
      ${owned ? '<div class="owned-tag">มีแล้ว</div>' : ''}
      <div class="char-avatar">${EL_ICON[c.el]}</div>
      <div class="char-name">${c.name}</div>
      <div class="char-stars"><span class="${c.stars===5?'star5':'star4'}">${'★'.repeat(c.stars)}</span></div>
      <span class="el el-${c.el}">${EL_ICON[c.el]} ${c.el}</span>
      <div class="char-role">${c.role}</div>
      <button class="toggle-own-btn" onclick="toggleOwned('${c.name}', event)">
        ${owned ? '✓ มีแล้ว — คลิกลบออก' : '+ เพิ่มว่ามีตัวนี้'}
      </button>
      ${hasBuild ? `<button class="toggle-own-btn" style="margin-top:4px;color:var(--gold);border-color:var(--border-gold)" onclick="goToBuild('${c.name}', event)">📖 ดู Build</button>` : ''}
    </div>`;
  }).join('');
}

function toggleOwned(name, e) {
  e.stopPropagation();
  if (S.ownedChars.has(name)) {
    S.ownedChars.delete(name);
  } else {
    S.ownedChars.add(name);
  }
  saveOwned();
  renderChars();
  renderTeams();
}

function goToBuild(name, e) {
  if (e) e.stopPropagation();
  if (!BUILDS[name]) return;
  switchTab('build', document.querySelectorAll('.tab')[4]);
  selectBuild(name);
}

function loadUID() {
  const uid = document.getElementById('uid-input').value.trim();
  if (uid.length < 6) { alert('กรุณากรอก UID ให้ถูกต้อง (6–9 หลัก)'); return; }
  const notice = document.querySelector('#sec-chars .notice');
  notice.innerHTML = `✅ โหลด UID <strong>${uid}</strong> แล้ว (แสดงข้อมูลตัวอย่าง) —
    เชื่อมต่อ <a href="https://enka.network/" target="_blank" rel="noopener">Enka.Network</a>
    จริงๆ เพื่อดึงข้อมูล showcase จาก in-game profile`;
}

/* ============================================================
   TEAMS
============================================================ */
function renderTeams() {
  document.getElementById('team-list').innerHTML = TEAMS.map(t => {
    const canUse = t.req.every(r => S.ownedChars.has(r));
    const membersHtml = t.members.map(m => {
      const c = CHARS.find(x => x.name === m);
      const has = S.ownedChars.has(m);
      return `<div class="member-chip${has?'':' missing'}">
        <span class="el el-${c?c.el:'Pyro'}" style="padding:1px 6px;font-size:10px">${c?EL_ICON[c.el]:''}</span>
        ${m} ${has?'✓':'✗'}
      </div>`;
    }).join('');
    const missing = t.req.filter(r => !S.ownedChars.has(r));
    return `<div class="team-card${canUse?' can-use':''}">
      <div class="team-header">
        <span class="team-name">${t.name}</span>
        <div style="display:flex;gap:6px;align-items:center">
          <span class="reaction-pill">${t.reaction}</span>
          <span class="diff-badge ${t.diff==='Easy'?'diff-easy':'diff-med'}">${t.diff}</span>
        </div>
      </div>
      <div class="team-members">${membersHtml}</div>
      <div class="team-desc">${t.desc}</div>
      ${canUse
        ? '<div class="team-status ok">✅ มีตัวละครครบ — ใช้ทีมนี้ได้เลย!</div>'
        : `<div class="team-status warn">⚠️ ขาด: ${missing.join(', ')} (req เท่านั้น)</div>`}
    </div>`;
  }).join('');
}

/* ============================================================
   MAP
============================================================ */
function setMapFilter(region, btn) {
  S.mapFilter = region;
  document.querySelectorAll('#map-filters .filter-btn').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  renderMap();
  document.getElementById('resource-popup').style.display = 'none';
}

function renderMap() {
  const res = S.mapFilter === 'all' ? RESOURCES : RESOURCES.filter(r => r.region === S.mapFilter);
  document.getElementById('map-dots').innerHTML = res.map(r =>
    `<circle class="resource-dot" cx="${r.x}" cy="${r.y}" r="7"
      fill="${r.color}" stroke="#05091A" stroke-width="2" opacity="0.92"
      onclick="showResource(${r.id})">
      <title>${r.name}</title>
    </circle>
    <text x="${r.x}" y="${r.y+19}" text-anchor="middle" fill="${r.color}"
      font-size="7.5" font-family="sans-serif" opacity="0.8">${r.name}</text>`
  ).join('');

  document.getElementById('map-legend').innerHTML = res.map(r =>
    `<div class="legend-item" onclick="showResource(${r.id})">
      <div class="legend-dot" style="background:${r.color}"></div>
      <span>${r.name}</span>
      <span style="margin-left:auto;color:var(--text-3);font-size:11px">${r.count}</span>
    </div>`
  ).join('');
}

function showResource(id) {
  const r = RESOURCES.find(x => x.id === id);
  if (!r) return;
  const popup = document.getElementById('resource-popup');
  popup.style.display = 'block';
  popup.innerHTML = `
    <div style="display:flex;align-items:center;gap:8px;margin-bottom:6px">
      <div style="width:13px;height:13px;border-radius:50%;background:${r.color};flex-shrink:0"></div>
      <strong style="color:var(--text);font-size:15px">${r.name}</strong>
      <span style="font-size:11px;color:var(--text-3);margin-left:auto">${r.region}</span>
    </div>
    <div style="font-size:13px;color:var(--text-2)">จำนวนในแผนที่: <strong style="color:var(--gold)">${r.count}</strong> แห่ง/ต้น</div>
    <div style="font-size:13px;color:var(--text-2);margin-top:4px">ใช้กับตัวละคร: ${r.use}</div>
    <div style="font-size:11px;color:var(--text-3);margin-top:10px">
      🗺️ ดูตำแหน่งละเอียด:
      <a href="https://genshin-impact-map.appsample.com/#${encodeURIComponent(r.name)}" target="_blank" rel="noopener">Interactive Map</a>
      หรือ
      <a href="https://genshin.honeyhunterworld.com/" target="_blank" rel="noopener">Honey Hunter</a>
    </div>`;
}

/* ============================================================
   BUILD
============================================================ */
function renderBuildChars() {
  document.getElementById('build-char-grid').innerHTML = Object.keys(BUILDS).map(name => {
    const c = CHARS.find(x => x.name === name);
    return `<button class="build-char-btn" id="bb-${name.replace(/ /g,'-')}"
      onclick="selectBuild('${name}')">
      ${c ? EL_ICON[c.el] : ''}<br>${name}
    </button>`;
  }).join('');
}

function selectBuild(name) {
  const b = BUILDS[name];
  if (!b) return;
  const c = CHARS.find(x => x.name === name);

  document.querySelectorAll('.build-char-btn').forEach(btn => btn.classList.remove('active'));
  const btn = document.getElementById('bb-'+name.replace(/ /g,'-'));
  if (btn) { btn.classList.add('active'); }
  S.activeBuild = name;

  const tips = b.tip.split('\n').map(t => `<div style="margin-bottom:3px">${t}</div>`).join('');

  const card = document.getElementById('build-guide');
  card.style.display = 'block';
  card.innerHTML = `
    <div class="build-char-header">
      <div class="build-avatar">${c ? EL_ICON[c.el] : ''}</div>
      <div>
        <div class="build-char-name">${name}</div>
        <div style="display:flex;gap:8px;align-items:center;margin-top:4px;flex-wrap:wrap">
          <span class="el el-${b.el}">${EL_ICON[b.el]} ${b.el}</span>
          <span style="font-size:13px;color:var(--text-2)">${b.role}</span>
          <span style="font-size:11px;color:var(--text-3)">${c ? c.wpn : ''}</span>
        </div>
      </div>
    </div>

    <div class="build-section">
      <div class="build-label">🏺 Artifact Set</div>
      <div class="build-value" style="color:var(--gold-light)">${b.artifact}</div>
      <div style="font-size:11px;color:var(--text-3);margin-top:3px">ทางเลือก: ${b.alt}</div>
    </div>

    <div class="build-section">
      <div class="build-label">⚔️ Weapon (เรียงตามความแรง)</div>
      <div>${b.weapons.map((w,i)=>`<span class="stat-pill">${i+1}. ${w}</span>`).join('')}</div>
    </div>

    <div class="build-section">
      <div class="build-label">📊 Main Stats ที่ต้องการ</div>
      <div>${b.mainStats.map(s=>`<div style="font-size:12px;color:var(--text-2);padding:3px 0;border-bottom:1px solid var(--border)">▸ ${s}</div>`).join('')}</div>
    </div>

    <div class="build-section">
      <div class="build-label">🎯 Sub Stats Priority</div>
      <div>${b.subStats.map(s=>`<span class="stat-pill">${s}</span>`).join('')}</div>
    </div>

    <div class="build-section">
      <div class="build-label">📚 Talent Book & ลำดับอัพ</div>
      <div class="build-value">${b.book}</div>
      <div style="font-size:12px;color:var(--text-3);margin-top:3px">ลำดับ: <strong style="color:var(--text-2)">${b.talent}</strong></div>
    </div>

    <div class="tip-box">
      <strong>💡 Tips สำคัญ</strong>
      <div style="margin-top:8px">${tips}</div>
    </div>`;

  card.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
}

/* ============================================================
   INIT
============================================================ */
function init() {
  initStars();
  initDaily();
  renderChars();
  renderTeams();
  renderMap();
  renderBuildChars();
}

init();
</script>
</body>
</html>
